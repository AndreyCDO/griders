//@version=6
indicator("Griders GRID DCA 2.6 + 3.1", overlay=true, max_labels_count=500)

bbLength = input.int(20, "Bollinger length", minval=5, maxval=100)
bbMult = input.float(2.0, "Bollinger multiplier", minval=0.5, step=0.1)
rsiLength = input.int(14, "RSI length", minval=2, maxval=100)
atrLength = input.int(14, "ATR length", minval=2, maxval=100)
emaFastLength = input.int(9, "Fast EMA", minval=1, maxval=100)
emaMidLength = input.int(21, "Mid EMA", minval=2, maxval=200)
emaSlowLength = input.int(50, "Slow EMA", minval=5, maxval=300)
volumeLength = input.int(30, "Volume baseline", minval=5, maxval=200)
minVolumeRatio = input.float(0.45, "GRID 2.6 min volume ratio", minval=0.1, step=0.05)
maxAtrPct = input.float(4.0, "GRID 2.6 max ATR, %", minval=0.1, step=0.1)
maxBbWidthPct = input.float(3.5, "GRID 2.6 range BB width, %", minval=0.1, step=0.1)
useMacroFilter = input.bool(true, "Use BTC/ETH market guard")
btcSymbol = input.symbol("BYBIT:BTCUSDT.P", "BTC futures symbol")
ethSymbol = input.symbol("BYBIT:ETHUSDT.P", "ETH futures symbol")
macroMove1Limit = input.float(0.8, "GRID 2.6 BTC/ETH 1-bar guard, %", minval=0.1, step=0.1)
macroMove3Limit = input.float(1.2, "GRID 2.6 BTC/ETH 3-bar guard, %", minval=0.1, step=0.1)
maxLongRedCandlePct = input.float(0.7, "GRID 2.6 block long red candle, %", minval=0.1, step=0.1)
maxShortGreenCandlePct = input.float(0.7, "GRID 2.6 block short green candle, %", minval=0.1, step=0.1)

v3MinVolumeRatio = input.float(0.75, "GRID 3.1 min volume ratio", minval=0.1, step=0.05)
v3MaxAtrPct = input.float(3.2, "GRID 3.1 max ATR, %", minval=0.1, step=0.1)
v3MaxBbWidthPct = input.float(2.8, "GRID 3.1 range BB width, %", minval=0.1, step=0.1)
v3MacroMove1Limit = input.float(0.55, "GRID 3.1 BTC/ETH 1-bar guard, %", minval=0.1, step=0.05)
v3MacroMove3Limit = input.float(0.9, "GRID 3.1 BTC/ETH 3-bar guard, %", minval=0.1, step=0.05)
v3MaxLongRedCandlePct = input.float(0.5, "GRID 3.1 block long red candle, %", minval=0.1, step=0.05)
v3MaxShortGreenCandlePct = input.float(0.5, "GRID 3.1 block short green candle, %", minval=0.1, step=0.05)

emaFast = ta.ema(close, emaFastLength)
emaMid = ta.ema(close, emaMidLength)
emaSlow = ta.ema(close, emaSlowLength)
rsi = ta.rsi(close, rsiLength)
rsi15 = request.security(syminfo.tickerid, "15", ta.rsi(close, rsiLength))
rsi60 = request.security(syminfo.tickerid, "60", ta.rsi(close, rsiLength))
atrPct = ta.atr(atrLength) / close * 100.0
volumeRatio = volume / ta.sma(volume, volumeLength)
candlePct = open > 0 ? (close - open) / open * 100.0 : 0.0
barMovePct = close[1] > 0 ? (close - close[1]) / close[1] * 100.0 : 0.0

bbBasis = ta.sma(close, bbLength)
bbDev = bbMult * ta.stdev(close, bbLength)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev
bbWidthPct = bbBasis > 0 ? (bbUpper - bbLower) / bbBasis * 100.0 : 0.0
bbPosition = (bbUpper - bbLower) > 0 ? (close - bbLower) / (bbUpper - bbLower) * 100.0 : 50.0

bullTrend = emaFast > emaMid and emaMid > emaSlow
bearTrend = emaFast < emaMid and emaMid < emaSlow
rangeMarket = not bullTrend and not bearTrend and bbWidthPct <= maxBbWidthPct
v3RangeMarket = not bullTrend and not bearTrend and bbWidthPct <= v3MaxBbWidthPct

btcMove1 = request.security(btcSymbol, timeframe.period, close[1] > 0 ? (close - close[1]) / close[1] * 100.0 : 0.0)
btcMove3 = request.security(btcSymbol, timeframe.period, close[3] > 0 ? (close - close[3]) / close[3] * 100.0 : 0.0)
ethMove1 = request.security(ethSymbol, timeframe.period, close[1] > 0 ? (close - close[1]) / close[1] * 100.0 : 0.0)
ethMove3 = request.security(ethSymbol, timeframe.period, close[3] > 0 ? (close - close[3]) / close[3] * 100.0 : 0.0)

macroLongBlock = useMacroFilter and (btcMove1 <= -macroMove1Limit or ethMove1 <= -macroMove1Limit or btcMove3 <= -macroMove3Limit or ethMove3 <= -macroMove3Limit)
macroShortBlock = useMacroFilter and (btcMove1 >= macroMove1Limit or ethMove1 >= macroMove1Limit or btcMove3 >= macroMove3Limit or ethMove3 >= macroMove3Limit)
longBreakdown = bbPosition < 0 or candlePct <= -maxLongRedCandlePct or (barMovePct <= -maxLongRedCandlePct and volumeRatio >= 1.4) or (close < bbLower and volumeRatio >= 1.0)
shortBreakout = bbPosition > 100 or candlePct >= maxShortGreenCandlePct or (barMovePct >= maxShortGreenCandlePct and volumeRatio >= 1.4) or (close > bbUpper and volumeRatio >= 1.0)

v3MacroLongBlock = useMacroFilter and (btcMove1 <= -v3MacroMove1Limit or ethMove1 <= -v3MacroMove1Limit or btcMove3 <= -v3MacroMove3Limit or ethMove3 <= -v3MacroMove3Limit)
v3MacroShortBlock = useMacroFilter and (btcMove1 >= v3MacroMove1Limit or ethMove1 >= v3MacroMove1Limit or btcMove3 >= v3MacroMove3Limit or ethMove3 >= v3MacroMove3Limit)
v3LongBreakdown = bbPosition < 5 or candlePct <= -v3MaxLongRedCandlePct or (barMovePct <= -v3MaxLongRedCandlePct and volumeRatio >= 1.2) or (close < bbLower and volumeRatio >= 0.9)
v3ShortBreakout = bbPosition > 95 or candlePct >= v3MaxShortGreenCandlePct or (barMovePct >= v3MaxShortGreenCandlePct and volumeRatio >= 1.2) or (close > bbUpper and volumeRatio >= 0.9)

longRsiFilter = rsi15 >= 42 and rsi15 <= 58 and rsi60 >= 42 and rsi60 <= 68
shortRsiFilter = rsi15 >= 38 and rsi15 <= 60 and rsi60 >= 30 and rsi60 <= 60
rangeShortRsiFilter = rsi15 >= 58 and rsi60 <= 65
trendShortRsiFilter = rsi15 >= 38 and rsi15 <= 56 and rsi60 <= 58

pullbackUp = bullTrend and bbPosition >= 42 and bbPosition <= 58 and longRsiFilter and not longBreakdown and not macroLongBlock
pullbackDown = bearTrend and bbPosition >= 45 and bbPosition <= 78 and shortRsiFilter and not shortBreakout and not macroShortBlock
tradable = atrPct <= maxAtrPct and volumeRatio >= minVolumeRatio
rangeShort = rangeMarket and bbPosition >= 75 and rangeShortRsiFilter and not shortBreakout and not macroShortBlock
trendShort = bearTrend and trendShortRsiFilter and bbPosition >= 42 and bbPosition <= 78 and not shortBreakout and not macroShortBlock

v3LongRsiFilter = rsi15 >= 44 and rsi15 <= 56 and rsi60 >= 45 and rsi60 <= 64
v3ShortRsiFilter = rsi15 >= 40 and rsi15 <= 58 and rsi60 >= 32 and rsi60 <= 56
v3RangeShortRsiFilter = rsi15 >= 60 and rsi15 <= 72 and rsi60 <= 60
v3TrendShortRsiFilter = rsi15 >= 40 and rsi15 <= 54 and rsi60 <= 55

v3PullbackUp = bullTrend and bbPosition >= 44 and bbPosition <= 56 and v3LongRsiFilter and volumeRatio >= v3MinVolumeRatio and not v3LongBreakdown and not v3MacroLongBlock
v3PullbackDown = bearTrend and bbPosition >= 48 and bbPosition <= 72 and v3ShortRsiFilter and volumeRatio >= v3MinVolumeRatio and not v3ShortBreakout and not v3MacroShortBlock
v3Tradable = atrPct <= v3MaxAtrPct and volumeRatio >= v3MinVolumeRatio
v3RangeShort = v3RangeMarket and bbPosition >= 78 and bbPosition <= 95 and v3RangeShortRsiFilter and not v3ShortBreakout and not v3MacroShortBlock
v3TrendShort = bearTrend and v3TrendShortRsiFilter and bbPosition >= 48 and bbPosition <= 72 and not v3ShortBreakout and not v3MacroShortBlock

longSignal = barstate.isconfirmed and tradable and pullbackUp and not macroLongBlock
shortSignal = barstate.isconfirmed and tradable and (rangeShort or trendShort or pullbackDown) and not macroShortBlock
v3LongSignal = barstate.isconfirmed and v3Tradable and v3PullbackUp and not v3MacroLongBlock
v3ShortSignal = barstate.isconfirmed and v3Tradable and (v3RangeShort or v3TrendShort or v3PullbackDown) and not v3MacroShortBlock

marketStage = pullbackUp or pullbackDown ? "pullback" : bearTrend or bullTrend ? "trend" : "range"
v3MarketStage = v3PullbackUp or v3PullbackDown ? "pullback" : bearTrend or bullTrend ? "trend" : "range"
confidence = longSignal or shortSignal ? (marketStage == "range" ? 0.68 : 0.72) : 0.0
v3Confidence = v3LongSignal or v3ShortSignal ? (v3MarketStage == "range" ? 0.72 : 0.76) : 0.0

dcaStep = math.max(0.45, math.min(2.4, atrPct * (marketStage == "range" ? 0.85 : marketStage == "trend" ? 1.1 : 0.75)))
takeProfit = math.max(0.35, math.min(1.0, dcaStep * 0.55))
stopLoss = math.max(marketStage == "pullback" ? 3.5 : 3.0, math.min(6.5, dcaStep * 4.0))

v3DcaStep = math.max(0.55, math.min(2.2, atrPct * (v3MarketStage == "range" ? 0.95 : v3MarketStage == "trend" ? 1.15 : 0.85)))
v3TakeProfit = math.max(0.4, math.min(0.95, v3DcaStep * 0.55))
v3StopLoss = math.max(v3MarketStage == "pullback" ? 3.5 : 3.0, math.min(6.2, v3DcaStep * 4.0))

plot(emaFast, "Fast EMA", color=color.new(color.teal, 0))
plot(emaMid, "Mid EMA", color=color.new(color.blue, 0))
plot(emaSlow, "Slow EMA", color=color.new(color.orange, 0))
plot(bbUpper, "BB Upper", color=color.new(color.gray, 70))
plot(bbLower, "BB Lower", color=color.new(color.gray, 70))
plotshape(longSignal, "GRID 2.6 Long", shape.triangleup, location.belowbar, color=color.new(color.lime, 0), size=size.small, text="2.6 L")
plotshape(shortSignal, "GRID 2.6 Short", shape.triangledown, location.abovebar, color=color.new(color.red, 0), size=size.small, text="2.6 S")
plotshape(v3LongSignal, "GRID 3.1 Long", shape.circle, location.belowbar, color=color.new(color.green, 0), size=size.tiny, text="3.1 L")
plotshape(v3ShortSignal, "GRID 3.1 Short", shape.circle, location.abovebar, color=color.new(color.maroon, 0), size=size.tiny, text="3.1 S")

makePayload(strategyCode, side, stage, conf, step, tp, sl) =>
    string payload = "{"
    payload := payload + "\"strategy\":\"" + strategyCode + "\","
    payload := payload + "\"source\":\"tradingview\","
    payload := payload + "\"signal_id\":\"" + strategyCode + "-" + syminfo.ticker + "-" + str.tostring(time) + "-" + side + "\","
    payload := payload + "\"pair\":\"" + syminfo.ticker + "\","
    payload := payload + "\"side\":\"" + side + "\","
    payload := payload + "\"confidence\":" + str.tostring(conf, "#.##") + ","
    payload := payload + "\"market_stage\":\"" + stage + "\","
    payload := payload + "\"atr_pct\":" + str.tostring(atrPct, "#.##") + ","
    payload := payload + "\"volume_ratio\":" + str.tostring(volumeRatio, "#.##") + ","
    payload := payload + "\"bb_position\":" + str.tostring(bbPosition, "#.##") + ","
    payload := payload + "\"bb_width_pct\":" + str.tostring(bbWidthPct, "#.##") + ","
    payload := payload + "\"rsi\":" + str.tostring(rsi15, "#.##") + ","
    payload := payload + "\"rsi_15m\":" + str.tostring(rsi15, "#.##") + ","
    payload := payload + "\"rsi_60m\":" + str.tostring(rsi60, "#.##") + ","
    payload := payload + "\"candle_pct\":" + str.tostring(candlePct, "#.##") + ","
    payload := payload + "\"bar_move_pct\":" + str.tostring(barMovePct, "#.##") + ","
    payload := payload + "\"btc_move_1\":" + str.tostring(btcMove1, "#.##") + ","
    payload := payload + "\"btc_move_3\":" + str.tostring(btcMove3, "#.##") + ","
    payload := payload + "\"eth_move_1\":" + str.tostring(ethMove1, "#.##") + ","
    payload := payload + "\"eth_move_3\":" + str.tostring(ethMove3, "#.##") + ","
    payload := payload + "\"dca_percent\":" + str.tostring(step, "#.##") + ","
    payload := payload + "\"take_profit\":" + str.tostring(tp, "#.##") + ","
    payload := payload + "\"stop_loss\":" + str.tostring(sl, "#.##") + ","
    payload := payload + "\"time\":" + str.tostring(time) + ","
    payload := payload + "\"bar_index\":" + str.tostring(bar_index)
    payload := payload + "}"
    payload

if longSignal
    alert(makePayload("grid_dca_v2", "long", marketStage, confidence, dcaStep, takeProfit, stopLoss), alert.freq_once_per_bar_close)

if shortSignal
    alert(makePayload("grid_dca_v2", "short", marketStage, confidence, dcaStep, takeProfit, stopLoss), alert.freq_once_per_bar_close)

if v3LongSignal
    alert(makePayload("grid_dca_v3", "long", v3MarketStage, v3Confidence, v3DcaStep, v3TakeProfit, v3StopLoss), alert.freq_once_per_bar_close)

if v3ShortSignal
    alert(makePayload("grid_dca_v3", "short", v3MarketStage, v3Confidence, v3DcaStep, v3TakeProfit, v3StopLoss), alert.freq_once_per_bar_close)
