# Normalize line endings: store LF in the repository, check out CRLF on
# Windows and LF on Linux/macOS. Keeps diffs clean across dev machines and
# the production server (Linux).
* text=auto eol=lf

# Explicit text types.
*.py   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.pine text eol=lf
*.sh   text eol=lf
*.yml  text eol=lf
*.txt  text eol=lf

# Windows-only helper scripts stay CRLF.
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary artifacts (never normalize).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.gz   binary
*.zip  binary
*.sqlite3 binary
